{
  "name": "@asciimoth/formular-menu",
  "version": "0.1.0",
  "description": "Dependency-free browser frontend for Formular JSON menus.",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "main": "./src/formular-menu.js",
  "module": "./src/formular-menu.js",
  "types": "./types/formular-menu.d.ts",
  "files": [
    "src/formular-menu.js",
    "types/",
    "docs/",
    "schemas/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./types/formular-menu.d.ts",
      "import": "./src/formular-menu.js",
      "default": "./src/formular-menu.js"
    }
  },
  "scripts": {
    "build:demo:wasm": "GOOS=js GOARCH=wasm go build -o demo/public/formular-demo.wasm ./demo/backend",
    "copy:wasm-exec": "mkdir -p demo/public && install -m 0644 \"$(go env GOROOT)/lib/wasm/wasm_exec.js\" demo/public/wasm_exec.js",
    "prepare:demo": "pnpm run copy:wasm-exec && pnpm run build:demo:wasm",
    "build:pages": "pnpm run prepare:demo && rm -rf dist && mkdir -p dist && cp -R index.html demo src docs schemas types README.md LICENSE package.json dist/ && touch dist/.nojekyll",
    "demo": "pnpm run prepare:demo && vite --host 127.0.0.1 --port 5173 --strictPort",
    "test": "node --test tests/*.test.js",
    "test:e2e": "pnpm run prepare:demo && playwright test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "formular",
    "forms",
    "menu",
    "web-components",
    "wasm"
  ],
  "author": "asciimoth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asciimoth/formular.git"
  },
  "bugs": {
    "url": "https://github.com/asciimoth/formular/issues"
  },
  "homepage": "https://github.com/asciimoth/formular#readme",
  "unpkg": "./src/formular-menu.js",
  "jsdelivr": "./src/formular-menu.js",
  "cdnjs": {
    "name": "formular-menu",
    "filename": "formular-menu.js",
    "files": [
      "src/formular-menu.js"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
