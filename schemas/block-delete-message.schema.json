{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asciimoth.github.io/formular/schemas/block-delete-message.schema.json",
  "title": "Backend Block Delete Message",
  "allOf": [
    { "$ref": "common.schema.json#/$defs/messageBase" },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "menuId", "menuGeneration", "blockId"],
      "properties": {
        "type": { "const": "block.delete" },
        "menuId": { "$ref": "common.schema.json#/$defs/menuId" },
        "menuGeneration": { "$ref": "common.schema.json#/$defs/generation" },
        "blockId": { "$ref": "common.schema.json#/$defs/id" }
      }
    }
  ]
}
