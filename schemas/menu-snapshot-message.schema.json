{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asciimoth.github.io/formular/schemas/menu-snapshot-message.schema.json",
  "title": "Backend Menu Snapshot Message",
  "allOf": [
    { "$ref": "common.schema.json#/$defs/messageBase" },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "menuId", "menuGeneration", "blocks"],
      "properties": {
        "type": { "const": "menu.snapshot" },
        "menuId": { "$ref": "common.schema.json#/$defs/menuId" },
        "menuGeneration": { "$ref": "common.schema.json#/$defs/generation" },
        "force": { "type": "boolean", "default": false },
        "blocks": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/block" }
        }
      }
    }
  ]
}
